# ===========================================================================
# nrs-automated-transcriptions — environment variables
# Copy to .env.local for local dev; configure same values in Vercel project.
# ===========================================================================

# --- Auth (admin → service) -----------------------------------------------
# Long random string (e.g. `openssl rand -hex 32`). Required header on all
# /api/jobs* requests:  Authorization: Bearer <token>
ADMIN_BEARER_TOKEN=

# --- Anthropic (Claude — cleanup + translation) ---------------------------
ANTHROPIC_API_KEY=

# --- Deepgram (Nova-3 — primary transcription) ----------------------------
# Up to 10 keys for rotation on 429/402 (rate limit / credits exhausted).
# Only DEEPGRAM_API_KEY is required; others are optional fallbacks.
DEEPGRAM_API_KEY=
DEEPGRAM_API_KEY_2=
DEEPGRAM_API_KEY_3=
DEEPGRAM_API_KEY_4=
DEEPGRAM_API_KEY_5=
DEEPGRAM_API_KEY_6=
DEEPGRAM_API_KEY_7=

# --- Groq (Whisper large-v3 — fallback transcription) ---------------------
# Free tier with rate limits. Up to 4 keys for rotation.
GROQ_API_KEY=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=

# --- OpenAI (text-embedding-3-small — for OpenSearch indexing) ------------
OPENAI_API_KEY=

# --- DynamoDB (job state store) -------------------------------------------
# Reuses the same AWS account as ask-niranjana-swami (eu-central-1).
DYNAMODB_REGION=eu-central-1
DYNAMODB_ACCESS_KEY=
DYNAMODB_SECRET_KEY=
DYNAMODB_TABLE_JOBS=nrs-transcribe-jobs
DYNAMODB_TABLE_LECTURES=nrs-lectures-auto-transcribe

# --- OpenSearch (downstream indexing target) ------------------------------
# Same cluster as ask-niranjana-swami's ask-nrs-lectures index.
OPENSEARCH_URL=https://148.251.70.122:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=
OPENSEARCH_INDEX=ask-nrs-lectures

# --- Pipeline tuning ------------------------------------------------------
# Default model for Claude cleanup + translation. Sonnet 4.6 = best quality.
# Switch to claude-haiku-4-5 to cut cost ~5x with mild quality loss.
CLAUDE_MODEL=claude-sonnet-4-5

# Max concurrent jobs the Vercel function will process. Bound by Deepgram key
# count (we have up to 10 with rotation).
MAX_CONCURRENT_JOBS=3
